{
  "name": "harbor",
  "private": true,
  "version": "0.9.36",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "core:wasm": "wasm-pack build vayra-core --target web --out-dir pkg",
    "core:wasm:smoke": "node scripts/smoke-vayra-core.mjs",
    "predev": "pnpm core:wasm",
    "dev": "vite",
    "prebuild": "pnpm core:wasm",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "tauri": "tauri",
    "tauri:build:linux-system": "tauri build --config src-tauri/tauri.linux-system.conf.json",
    "setup:libmpv": "node scripts/fetch-libmpv.mjs",
    "setup:ffmpeg": "node scripts/fetch-ffmpeg.mjs",
    "setup:fonts": "node scripts/fetch-fonts.mjs",
    "bundle:macos": "node scripts/bundle-libmpv-macos.mjs",
    "tauri:build:macos": "tauri build --bundles app && node scripts/bundle-libmpv-macos.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.8",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "dompurify": "^3.4.11",
    "gifenc": "^1.0.3",
    "hls.js": "^1.6.16",
    "jsqr": "^1.4.0",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.460.0",
    "mpegts.js": "^1.8.0",
    "parse-torrent-title": "^3.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.4",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
