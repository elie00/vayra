{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbor",
  "version": "0.9.36",
  "identifier": "app.harbor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Harbor",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "backgroundColor": [0, 0, 0, 255],
        "shadow": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "center": true,
        "additionalBrowserArgs": "--disk-cache-size=104857600 --media-cache-size=52428800 --autoplay-policy=no-user-gesture-required --disable-features=HardwareMediaKeyHandling"
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost ipc: http://ipc.localhost; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src * data: blob: asset: https://asset.localhost; media-src * data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src * data: blob: asset: https://asset.localhost ipc: http://ipc.localhost; worker-src 'self' blob:; child-src 'self' blob:; frame-src 'self' https:; object-src 'none'; base-uri 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Video",
    "shortDescription": "A client for the Stremio protocol",
    "longDescription": "Harbor is an independent, open source media player and a client for the open Stremio addon protocol. It hosts and indexes no content: what you can browse or play depends entirely on the addons and services you configure. Native libmpv playback, a Rust stream ranking core, watch parties, Live TV, and per-service catalogs.",
    "homepage": "https://harbor.site",
    "publisher": "Harbor",
    "fileAssociations": [
      {
        "ext": ["mkv", "mp4", "avi", "mov", "webm", "m4v"],
        "name": "HarborVideo",
        "description": "Video file",
        "role": "Viewer"
      }
    ],
    "createUpdaterArtifacts": false,
    "targets": ["app", "dmg", "deb", "rpm", "appimage", "nsis"],
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg", "binaries/ffprobe"],
    "resources": {
      "fonts/*": "fonts/"
    },
    "licenseFile": "installer/eula.txt",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libmpv2 | libmpv1",
          "libwebkit2gtk-4.1-0",
          "libgl1",
          "libegl1",
          "libayatana-appindicator3-1",
          "libssl3",
          "ca-certificates",
          "gstreamer1.0-plugins-good",
          "gstreamer1.0-plugins-bad",
          "gstreamer1.0-libav"
        ]
      },
      "rpm": {
        "depends": [
          "mpv-libs",
          "webkit2gtk4.1",
          "mesa-libGL",
          "mesa-libEGL",
          "libappindicator-gtk3",
          "openssl-libs",
          "ca-certificates"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./installer-hooks.nsh",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [{ "scheme": ["harbor"] }],
      "desktop": {
        "schemes": ["harbor", "stremio"]
      }
    },
    "updater": {
      "endpoints": ["https://harbor.site/updates/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyNjlEMjU4NjQ4OTM2MjAKUldRZ05vbGtXTkpwc3ZDQnlvZUYyL2VEWHgwODdJa2dkZ2xlNWk3emRWL1V0dXVrcUJlVmhCWEUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
