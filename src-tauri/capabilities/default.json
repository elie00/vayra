{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities. Aux windows (pip, browser, modal overlay) have their own minimal capability files.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "core:window:allow-set-decorations",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-current-monitor",
    "core:window:allow-outer-size",
    "core:window:allow-outer-position",
    "core:webview:allow-set-webview-zoom",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*:*/**" },
        { "url": "http://*:*/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "dialog:allow-message",
    "deep-link:default",
    "process:default",
    "clipboard-manager:allow-write-image",
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$PICTURE/Harbor" }, { "path": "$PICTURE/Harbor/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$PICTURE/Harbor" }, { "path": "$PICTURE/Harbor/**" }]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [{ "path": "**" }]
    }
  ]
}
