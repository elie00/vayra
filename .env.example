# Optional public overrides for local or staging Supabase projects.
# Production VAYRA already embeds its public project URL and publishable key.
# Never put a service-role key or provider secret in a VITE_* variable.
VITE_VAYRA_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_VAYRA_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
