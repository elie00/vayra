# Public Supabase project settings used by VAYRA email authentication.
# The anon/publishable key is safe to ship in the client. Never put a
# service-role key or an OAuth provider secret in a VITE_* variable.
VITE_VAYRA_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_VAYRA_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
